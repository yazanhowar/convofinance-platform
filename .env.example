# ---------------------------------------------------------------------------
# convofinance-platform — environment variables
# Copy to .env.local and fill in. NEVER commit real keys.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (public) key — browser-safe, read-only under RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role (secret) key — server-side ONLY. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for the conversational analysis endpoint.
ANTHROPIC_API_KEY=
